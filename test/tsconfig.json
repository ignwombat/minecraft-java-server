{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",

        "lib": ["ESNext"],
        "esModuleInterop": true,
        "strict": true,
        "allowImportingTsExtensions": true,

        "types": ["node"],
        
        "rootDir": ".",
        "outDir": "./dist",

        "noEmit": true
    },

    "include": ["./**/*"],
    "exclude": ["node_modules"]
}